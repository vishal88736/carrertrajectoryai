# ── CareerTrajectory AI — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your API keys.

# Groq API (free tier) for Llama 3 LLM Copilot
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# GitHub Personal Access Token for live behavioral signal collection
# Create at: https://github.com/settings/tokens (scope: public_repo)
GITHUB_TOKEN=ghp_...

# Kaggle API credentials (optional)
# Get at: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_key

# ── Feature Flags (optional — all default to true when API keys are present) ──
# CT_USE_SEMANTIC_EMBEDDINGS=true
# CT_USE_CHROMADB=true
# CT_USE_LIVE_GITHUB=true
# CT_USE_LIVE_LEETCODE=true
# CT_USE_LIVE_KAGGLE=true
# CT_USE_LLM_COPILOT=true
# CT_USE_ML_RANKING=true
